a:2:{s:3:"exp";i:1779253819;s:3:"val";a:3:{s:53:"/img/artikel/misteri-minggu-palma-gereja-katolik.webp";a:6:{s:9:"image_url";s:53:"/img/artikel/misteri-minggu-palma-gereja-katolik.webp";s:8:"alt_text";s:89:"Perarakan Minggu Palma komunitas Paroki SMDTBA Tulungagung menyusuri jalan dengan khidmat";s:7:"caption";s:117:"Umat Paroki SMDTBA Tulungagung melangkah masuk gereja dengan palma — pembukaan pekan paling sakral sepanjang tahun.";s:10:"title_attr";s:62:"Perarakan Palma Pembukaan Pekan Suci Paroki SMDTBA Tulungagung";s:18:"schema_description";s:217:"Foto prosesi palma dalam Minggu Palma di Paroki SMDTBA Tulungagung yang membuka Pekan Suci 2026. Umat Gereja Katolik Tulungagung merayakan masuknya Kristus ke Yerusalem dengan mengarak daun palma yang telah diberkati.";s:14:"image_keywords";s:187:"["kabupaten tulungagung","gereja katolik tulungagung","paroki smdtba","minggu suci","katolik","ditinggalkan","palma","paroki tulungagung","tulungagung","derita:","minggu palma","sebagai"]";}s:46:"/img/artikel/misteri-di-hari-minggu-palma.webp";a:6:{s:9:"image_url";s:46:"/img/artikel/misteri-di-hari-minggu-palma.webp";s:8:"alt_text";s:63:"Pemberkatan palma di luar Gereja SMDTBA sebelum perarakan masuk";s:7:"caption";s:117:"Umat Paroki SMDTBA Tulungagung melangkah masuk gereja dengan palma — pembukaan pekan paling sakral sepanjang tahun.";s:10:"title_attr";s:39:"Prosesi Palma Gereja SMDTBA Tulungagung";s:18:"schema_description";s:221:"Dokumentasi Minggu Palma di Gereja SMDTBA Tulungagung, pembukaan liturgi Pekan Suci yang paling sakral. Prosesi daun palma dan bacaan Sengsara panjang mengantar komunitas Paroki SMDTBA Tulungagung memasuki Triduum Paskah.";s:14:"image_keywords";s:190:"["raja","arti","paroki kabupaten tulungagung","disambut","minggu suci","prosesi palma smdtba 2026","smdtba tulungagung","sebagai","minggu palma","paroki tulungagung","minggu","ditinggalkan"]";}s:87:"https://www.parokitulungagung.org/img/artikel/perayaan-minggu-palma-gereja-katolik.webp";a:6:{s:9:"imag