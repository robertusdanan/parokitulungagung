a:2:{s:3:"exp";i:1779253825;s:3:"val";a:1:{i:0;a:16:{s:2:"id";s:13:"arttby4pn5900";s:4:"menu";s:6:"kronik";s:5:"judul";s:34:"MISA PAGUYUPAN KELUARGA TERPANGGIL";s:9:"ringkasan";s:170:"Misa PAGUTER St Maria DTBA , Tulungagung Paguyupan Keluarga Terpanggil.Sungguh Anugerah yang sangat Besar boleh berada di tengah keluarga" dalam Panggilan Khusus ini.🌹";s:6:"konten";s:777:"<p><br></p><p>Misa&nbsp;PAGUTER St Maria DTBA , Tulungagung&nbsp;</p><p>🧑‍🧑‍🧒‍🧒 ✝️ Paguyupan Keluarga Terpanggil</p><p>.</p><p>Sungguh Anugerah yang sangat Besar boleh berada di tengah keluarga" dalam Panggilan Khusus ini.&nbsp;</p><p>🌹Berdoa, saling mendukung satu sama lain dan bersilahturahmi, memperkuat Persaudaraan&nbsp;</p><p>.</p><p>Semoga semakin banyak kaum muda yang berani menjawab Panggilan Khusus,</p><p>Serta Keluarga" yang ikhlas dan Rela atas Kehendak-Nya&nbsp;</p><p>.</p><p>Menjalani Perutusan Mewartakan dan Membangun Gereja, untuk Mewujudkan Kerajaan Allah di tengah Dunia, melalui Tindakan dan Kehidupan Umat beriman.</p><p>⛪</p><p class="ql-align-center"><br></p><p>📷fotoby @masAndre@pakPungky</p><p>📹videoeditby@Erit</p>";s:9:"thumbnail";s:52:"/img/artikel/misa-paguyuban-keluarga-terpanggil.webp";s:6:"status";s:9:"published";s:7:"penulis";s:25:"Komsos Paroki Tulungagung";s:4:"slug";s:34:"misa-paguyupan-keluarga-terpanggil";s:10:"created_at";s:25:"2026-03-15T11:08:11+00:00";s:10:"updated_at";s:32:"2026-05-10T12:42:45.682048+00:00";s:12:"published_at";s:25:"2026-03-15T11:08:35+00:00";s:4:"tags";s:65:"misa keluarga terpanggil, misa gereja katolik, paroki tulungagung";s:7:"tanggal";s:10:"2026-03-21";s:10:"view_count";i:23;s:6:"_score";d:4.9787234042553194512947811745107173919677734375;}}}